# Required for model calls
OPENROUTER_API_KEY=

# Weak free models may invent tool names that are not registered; prefer a tool-capable id if needed.
OPENROUTER_MODEL=openrouter/free

# Root of the game / TypeScript monorepo (must contain package.json). Defaults to this project directory if unset.
# REPO_ROOT=/absolute/path/to/your-game-repo

# When true, Reviewer agent gets a tool that runs: npm run validate:scenes (cwd=REPO_ROOT)
ENABLE_VALIDATE_SCENES_TOOL=false

# When true (default), Auditor + Senior get execute_command/bash (allowlisted npm scripts only; see tools/allowlisted_shell.py)
ENABLE_REPO_SHELL_TOOLS=true

# Default max rework iterations after Reviewer rejects items (AuditFlow loop)
AUDIT_FLOW_MAX_ITERATIONS=4

# Agno session + user memory + workflows + AgentOS Studio: SQLite (default when unset).
# Same SqliteDb is shared by agents, teams, AuditFlow workflow, and AgentOS.
# Set to none (or off / false / 0) to disable persistence.
# Note: if AGNO_MEMORY_DB is already set in your shell, python-dotenv will NOT override it (override=False).
# AGNO_MEMORY_DB=none
# AGNO_MEMORY_SQLITE_PATH=

# AgentOS Knowledge (RAG): LanceDB + local FastEmbed embeddings.
# Any value other than none/off/false/0 enables it (default when unset is enabled).
# Requires fastembed + lancedb in the active Python (pip install fastembed lancedb).
AGNO_KNOWLEDGE=lancedb
# AGNO_KNOWLEDGE=none   # uncomment to disable
